/// Action (ADR-0001, plugin extension point): the declarative
/// projection of imperative work — the user fills typed fields, the
/// plugin's executor turns them into real operations at runtime.
///
/// The core owns execution policies (timeout, retry), the capability
/// contract (requires/grants), and the published contract (outputs,
/// artifacts). Concrete behavior and configuration are the plugin's
/// typed schema (subclasses).
///
/// PUBLISHED CONTRACT — typed nested classes: a plugin declares its
/// outputs/artifacts as real classes, and wires them in the action:
///
///   class PushOutputs extends action.Outputs {
///     digest: values.RuntimeRef
///   }
///   class Push extends DockerAction {
///     outputs: PushOutputs = let (o = mkOutput) new {
///       digest = o.apply("digest")
///     }
///   }
///
/// Users reference `push.outputs.digest` — a typed class field:
/// IDE-navigable, a typo is a type error. The contract is a first-class
/// TYPE (codegen target: the struct the executor fills). Declared wire
/// names are DERIVED from the object, and each field name must EQUAL
/// its wire name (verified at eval) — drift is unrepresentable.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.action

import "capability.pkl"
import "values.pkl"

typealias Name = String(matches(Regex(#"[a-z][a-z0-9-]*"#)))

/// Retries are invisible to the DAG: dependency edges see only the
/// final outcome; every attempt is visible as observation-plane
/// events.
class RetryPolicy {
  attempts: Int(isPositive) = 1
  backoff: Duration = 10.s
}

/// Marker base of plugin-declared outputs classes (typed contracts of
/// runtime outputs; fields are values.RuntimeRef).
abstract class Outputs {}

/// Marker base of plugin-declared artifacts classes (fields are
/// values.ArtifactRef).
abstract class Artifacts {}

abstract class Action {
  name: Name
  description: String?

  /// The model owns time limits at the action level only (ADR-0001).
  timeout: Duration = 5.min
  retry: RetryPolicy = new RetryPolicy {}

  /// Capability contract: what this action needs from its host, and
  /// what it adds to it (a visible host-state mutation).
  requires: Listing<capability.CapabilityName>
  grants: Listing<capability.CapabilityName>

  /// The action's published runtime outputs, as a typed object
  /// (subclass of Outputs declared by the plugin). Null = no outputs.
  outputs: Outputs?

  /// The action's published artifacts, same convention.
  artifacts: Artifacts?

  /// Factory injected into outputs wiring:
  ///   outputs: PushOutputs = let (o = mkOutput) new { digest = o.apply("digest") }
  hidden mkOutput: (String) -> values.RuntimeRef =
    (o) -> new values.RuntimeRef { expr = "actions.\(name).outputs.\(o)" }

  /// Factory for artifact wiring, same shape.
  hidden mkArtifact: (String) -> values.ArtifactRef =
    (a) -> new values.ArtifactRef { expr = "actions.\(name).artifacts.\(a)" }

  // --- derived published contract (wire names from the typed objects) ---

  hidden wireNames = (obj: Typed?, what: String) ->
    if (obj == null) List()
    else obj.toMap().entries.map((e) ->
      let (wire = (e.value as values.ValueRef).expr.split(".").last)
        if (e.key != wire)
          throw("action `\(name)`: \(what) field `\(e.key)` must equal its wire name `\(wire)` — field name and wire name may not drift")
        else wire)

  hidden outputNames: List<String> = wireNames.apply(outputs, "output")
  hidden artifactNames: List<String> = wireNames.apply(artifacts, "artifact")
}
