/// Action (ADR-0001, plugin extension point): the declarative
/// projection of imperative work — the user fills typed fields, the
/// plugin's executor turns them into real operations at runtime.
///
/// The core owns execution policies (timeout, retry), the capability
/// contract (requires/grants), and the published contract (outputs,
/// artifacts). Concrete behavior and configuration are the plugin's
/// typed schema (subclasses).
///
/// PUBLISHED CONTRACT — single-declaration convention: a concrete
/// action class declares each output/artifact as ONE field named
/// exactly like the output:
///
///   class Push extends DockerAction {
///     digest = output("digest")
///     log = artifact("log")
///   }
///
/// Users reference `push.digest` — IDE-navigable; a typo is an eval
/// error. The declared sets are DERIVED from these fields, and the
/// field name must EQUAL the wire name (verified at eval), so drift
/// between navigation surface and runtime name is unrepresentable.
/// Outputs share the field namespace with the action's config —
/// deliberate: config and results are attributes of one object, as in
/// HCL resources.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.action

import "capability.pkl"
import "values.pkl"

typealias Name = String(matches(Regex(#"[a-z][a-z0-9-]*"#)))

/// Retries are invisible to the DAG: dependency edges see only the
/// final outcome; every attempt is visible as observation-plane
/// events.
class RetryPolicy {
  attempts: Int(isPositive) = 1
  backoff: Duration = 10.s
}

abstract class Action {
  name: Name
  description: String?

  /// The model owns time limits at the action level only (ADR-0001).
  timeout: Duration = 5.min
  retry: RetryPolicy = new RetryPolicy {}

  /// Capability contract: what this action needs from its host, and
  /// what it adds to it (a visible host-state mutation).
  requires: Listing<capability.CapabilityName>
  grants: Listing<capability.CapabilityName>

  /// Factory for a typed output reference (used only in `x = output("x")`
  /// field declarations of concrete action classes).
  function output(o: String): values.RuntimeRef =
    new { expr = "actions.\(name).outputs.\(o)" }

  /// Factory for a typed artifact reference (`y = artifact("y")` fields).
  function artifact(a: String): values.ArtifactRef =
    new { expr = "actions.\(name).artifacts.\(a)" }

  // --- derived published contract (no second declaration to drift) ---

  /// (field name, deferred ref) pairs of this instance, by ref class.
  hidden refFields = (t: Class) ->
    this.toMap().filter((_k, v) -> v.getClass() == t)

  /// Declared runtime outputs, derived from RuntimeRef fields; the
  /// field name must equal the wire name.
  hidden outputs: List<String> =
    refFields.apply(values.RuntimeRef).entries.map((e) ->
      let (wire = (e.value as values.RuntimeRef).expr.split(".").last)
        if (e.key != wire)
          throw("action `\(name)`: output field `\(e.key)` must equal its wire name `\(wire)` (write `\(wire) = output(\"\(wire)\")`)")
        else wire)

  /// Declared artifacts, derived from ArtifactRef fields, same rule.
  hidden artifacts: List<String> =
    refFields.apply(values.ArtifactRef).entries.map((e) ->
      let (wire = (e.value as values.ArtifactRef).expr.split(".").last)
        if (e.key != wire)
          throw("action `\(name)`: artifact field `\(e.key)` must equal its wire name `\(wire)` (write `\(wire) = artifact(\"\(wire)\")`)")
        else wire)
}
