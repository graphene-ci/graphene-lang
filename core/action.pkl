/// Action (ADR-0001, plugin extension point): the declarative
/// projection of imperative work — the user fills typed fields, the
/// plugin's executor turns them into real operations at runtime.
///
/// The core owns execution policies (timeout, retry), the capability
/// contract (requires/grants), and the published contract (outputs,
/// artifacts). Concrete behavior and configuration are the plugin's
/// typed schema (subclasses).
///
/// PUBLISHED CONTRACT — classes are pure schema, nothing is
/// instantiated by plugin authors:
///
///   class PushOutputs extends action.Outputs {
///     digest: values.RuntimeRef
///   }
///   class Push extends DockerAction {
///     outputsSchema = PushOutputs        // a class value, no `new`
///   }
///
/// The base Action builds the reference object FROM the schema via
/// reflection: users write `push.outputs.digest` and get a RuntimeRef
/// addressed as `actions.<instance>.outputs.digest`. A typo fails eval
/// with a did-you-mean. Wire names ARE the schema field names — there
/// is nothing to drift and nothing to wire by hand. The outputs class
/// is a first-class type: the codegen target for the struct the
/// executor fills at runtime.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.action

import "pkl:reflect"

import "capability.pkl"
import "values.pkl"

typealias Name = String(matches(Regex(#"[a-z][a-z0-9-]*"#)))

/// Retries are invisible to the DAG: dependency edges see only the
/// final outcome; every attempt is visible as observation-plane
/// events.
class RetryPolicy {
  attempts: Int(isPositive) = 1
  backoff: Duration = 10.s
}

/// Marker base of plugin-declared outputs classes (typed contracts of
/// runtime outputs; fields are values.RuntimeRef).
abstract class Outputs {}

/// Marker base of plugin-declared artifacts classes (fields are
/// values.ArtifactRef).
abstract class Artifacts {}

abstract class Action {
  name: Name
  description: String?

  /// The model owns time limits at the action level only (ADR-0001).
  timeout: Duration = 5.min
  retry: RetryPolicy = new RetryPolicy {}

  /// Capability contract: what this action needs from its host, and
  /// what it adds to it (a visible host-state mutation).
  requires: Listing<capability.CapabilityName>
  grants: Listing<capability.CapabilityName>

  /// Pure schema markers: the plugin points at its outputs/artifacts
  /// classes. Null = the action publishes nothing of that kind.
  hidden outputsSchema: Class? = null
  hidden artifactsSchema: Class? = null

  // --- built by the base from the schema; plugins instantiate nothing ---

  /// Schema field names (= wire names; nothing to drift), with the
  /// field types validated against the expected reference class.
  hidden schemaFields = (schema: Class?, refClass: Class, what: String) ->
    if (schema == null) List()
    else reflect.Class(schema!!).allProperties.values.map((p) ->
      if (p.type is reflect.DeclaredType && (p.type as reflect.DeclaredType).referent.reflectee == refClass)
        p.name
      else
        throw("action `\(name)`: \(what) schema `\(reflect.Class(schema!!).name)` field `\(p.name)` must be typed \(refClass.simpleName)"))

  hidden outputNames: List<String> =
    schemaFields.apply(outputsSchema, values.RuntimeRef, "outputs")
  hidden artifactNames: List<String> =
    schemaFields.apply(artifactsSchema, values.ArtifactRef, "artifacts")

  /// Reference objects users navigate: `push.outputs.digest` yields a
  /// RuntimeRef addressed as actions.<name>.outputs.digest. Built from
  /// the schema by reflection; a typo fails eval with a did-you-mean.
  hidden outputs: Dynamic =
    let (owner = name)
      outputNames.fold(Map(), (acc: Map, o: String) ->
        acc.put(o, new values.RuntimeRef { expr = "actions.\(owner).outputs.\(o)" })).toDynamic()

  hidden artifacts: Dynamic =
    let (owner = name)
      artifactNames.fold(Map(), (acc: Map, a: String) ->
        acc.put(a, new values.ArtifactRef { expr = "actions.\(owner).artifacts.\(a)" })).toDynamic()
}
