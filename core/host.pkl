/// Host (ADR-0001): a pure role — a named execution place jobs bind
/// to. Carries NO machine parameters: hardware, image, and connection
/// details are the backing resource's responsibility. Jobs, in-run
/// capability accumulation, and telemetry all address the host by
/// name. The host->resource indirection keeps roles stable while
/// executors are swappable.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.host

import "capability.pkl"
import "resource.pkl"

typealias Name = String(matches(Regex(#"[a-z][a-z0-9-]*"#)))

class Host {
  name: Name

  /// The resource executing this role (object reference).
  backedBy: resource.Resource

  /// Capability baseline inherited from the backing resource at
  /// binding (ADR-0001: capability state is a host property; the
  /// baseline is inherited, grants accumulate per run per host).
  hidden baseline: List<capability.CapabilityName> = backedBy.baseline
}
