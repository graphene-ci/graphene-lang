/// Job (ADR-0001): the unit of scheduling — binds to exactly one host,
/// depends on other jobs (the DAG), carries an ordered non-empty
/// sequence of actions executed at that host by its resource's agent.
///
/// Failure semantics live on the dependency edge: a job declares under
/// which outcomes of a dependency it starts (default: success). Job
/// outcomes: success / failed / skipped / canceled.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.job

import "capability.pkl"
import "host.pkl"
import "action.pkl"

typealias Name = String(matches(Regex(#"[a-z][a-z0-9-]*"#)))

/// Reaction to a dependency's outcome:
///   "success" — start only if the dependency succeeded (default);
///   "failure" — start only if it failed (error handlers);
///   "always"  — start on any terminal outcome (cleanup, reports).
typealias EdgeCondition = "success" | "failure" | "always"

/// A dependency edge with an explicit start condition.
class Dependency {
  job: Job
  on: EdgeCondition = "success"
}

class Job {
  name: Name

  /// The host this job executes at (object reference).
  runsOn: host.Host

  /// Dependency edges. Sugar: a bare Job means { job = it; on = "success" }.
  needs: Listing<Job | Dependency>

  actions: Listing<action.Action>(length > 0)

  /// Edges normalized to Dependency (order preserved).
  hidden edges: List<Dependency> =
    needs.toList().map((n) ->
      if (n is Dependency) n else new Dependency { job = n })

  /// A job cannot depend on the same job through two edges — with a
  /// single condition per edge that is either redundant or
  /// contradictory (ADR-0001 invariant 9, v0 form).
  hidden edgesDistinct: Boolean = edges.isDistinctBy((e) -> e.job.name)

  /// Capabilities available at this job's host when it starts:
  /// the host baseline plus, transitively, grants of dependency jobs
  /// that run on the SAME host (per-host ledger — deliberately
  /// conservative for shared resources, ADR-0001).
  hidden availableCaps: List<capability.CapabilityName> =
    runsOn.baseline +
      edges.flatMap((e) ->
        if (e.job.runsOn == runsOn)
          e.job.availableCaps + e.job.grantedCaps
        else List())

  /// Everything this job's actions grant, in order.
  hidden grantedCaps: List<capability.CapabilityName> =
    actions.toList().flatMap((a) -> a.grants.toList())

  /// Walk actions in order: every requirement covered by the
  /// accumulated set; grants extend it (ADR-0001 invariant 4).
  hidden capsOk: Boolean =
    actions.toList()
      .fold(Pair(true, availableCaps), (acc: Pair<Boolean, List<capability.CapabilityName>>, a) ->
        Pair(
          acc.first && a.requires.toList().every((r) -> acc.second.contains(r)),
          acc.second + a.grants.toList()))
      .first

  /// First unsatisfied requirement, for a precise eval error.
  hidden missingCaps: List<capability.CapabilityName> =
    actions.toList()
      .fold(Pair(List(), availableCaps), (acc: Pair<List<capability.CapabilityName>, List<capability.CapabilityName>>, a) ->
        Pair(
          acc.first + a.requires.toList().filter((r) -> !acc.second.contains(r)),
          acc.second + a.grants.toList()))
      .first
}
