/// Observability (ADR-0001): first-class, declarative.
///
/// Emission is fixed by the model (every run graph node emits logs /
/// events / metrics by virtue of existing) — nothing to author there.
/// The declaration surface is sinks and routing. A system default sink
/// always exists; user declarations extend or redirect, they cannot
/// create blind spots in the system's own collection.
@ModuleInfo { minPklVersion = "0.32.0" }
module graphene.core.observability

typealias Stream = "logs" | "events" | "metrics"

/// Base of telemetry sinks (plugin extension point): where telemetry
/// is delivered. Concrete sinks are plugin schemas extending this.
abstract class Sink {
  /// Discriminator: routes to a sink executor at runtime.
  kind: String(!isEmpty)
  name: String(!isEmpty)
}

/// A routing rule: which streams go to which sink. Scope narrows down
/// the hierarchy (workflow default -> job -> action -> host) via the
/// canonical address prefix; empty scope = whole run.
class Route {
  sink: Sink
  streams: Listing<Stream>(length > 0, isDistinct)
  /// Canonical-address prefix, e.g. "jobs.load" or "hosts.db-0".
  scope: String?
}

class Observability {
  sinks: Listing<Sink>(isDistinctBy((s) -> s.name))
  routes: Listing<Route>
}
