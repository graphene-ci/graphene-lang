/// User-module entry point. A workflow file writes
/// `extends ".../core/template.pkl"`, declares resources/hosts/jobs as
/// named top-level properties, and fills `wf`.
///
/// Rendering is configured here: the artifact contains ONLY the
/// workflow (auxiliary top-level declarations never leak), object
/// references are flattened to names, deferred values appear as
/// placeholders, and computed demand is carried as metadata
/// (ADR-0001: render discipline, computable demand).
///
/// Inputs (hermetic eval): only parameters declared in `wf.inputs` are
/// readable, via `input(name)`; values come from external properties
/// (-p name=value). Reading an undeclared name is an eval error.
@ModuleInfo { minPklVersion = "0.32.0" }
open module graphene.core.template

import "workflow.pkl"
import "resource.pkl"
import "job.pkl"
import "values.pkl"

/// The single mandatory property of a user module.
wf: workflow.Workflow

/// Read a declared workflow input. The declaration must exist in
/// `wf.inputs`; the value comes from an external property or the
/// declared default; a required input with no value fails eval.
function input(name: String): String =
  let (spec = wf.inputs.getOrNull(name))
    if (spec == null)
      throw("undeclared input `\(name)`: declare it in wf.inputs (hermetic eval forbids ad-hoc reads)")
    else
      read?("prop:\(name)") ?? spec.default ??
        throw("missing required input: -p \(name)=... (\(spec.description ?? "no description"))")

/// --- artifact projection ---

local function renderResource(r: resource.Resource): Dynamic =
  if (r is resource.EphemeralResource)
    new Dynamic {
      name = r.name
      lifetime = "ephemeral"
      provider = r.provider
      hardware = r.hardware
      provides = r.baseline
    }
  else
    new Dynamic {
      name = r.name
      lifetime = "persistent"
      registryRef = (r as resource.PersistentClaim).registryRef
      providerKind = (r as resource.PersistentClaim).providerKind
      provides = r.baseline
    }

local function renderModel(w: workflow.Workflow): Dynamic = new {
  name = w.name
  inputs = w.inputs
  resources = new Listing {
    for (r in w.resources) { renderResource(r) }
  }
  hosts = new Listing {
    for (h in w.hosts) {
      new Dynamic {
        name = h.name
        backedBy = h.backedBy.name
      }
    }
  }
  jobs = new Listing {
    for (j in w.jobs) {
      new Dynamic {
        name = j.name
        runsOn = j.runsOn.name
        needs = j.edges.map((e) -> new Dynamic {
          job = e.job.name
          on = e.on
        })
        // hidden members (incl. the derived published contract) are
        // excluded from default rendering — re-attach explicitly
        actions = j.actions.toList().map((a) ->
          a.toDynamic().toMap()
            .put("outputs", a.outputs)
            .put("artifacts", a.artifacts))
      }
    }
  }
  when (w.observability != null) {
    observability = w.observability
  }
  demand = new Dynamic {
    ephemeral = w.ephemeralDemand
    attach = w.attachDemand
  }
}

output {
  value = renderModel(wf)
  renderer = new YamlRenderer {
    converters {
      [values.ValueRef] = (v: values.ValueRef) -> v.placeholder()
      [Duration] = (d: Duration) -> "\(d.toUnit("s").value)s"
      [DataSize] = (s: DataSize) -> "\(s.toUnit("mib").value)mib"
    }
  }
}
