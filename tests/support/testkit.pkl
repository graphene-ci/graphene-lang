/// Test-only concrete subclasses of the core extension points.
/// Real providers/actions live in graphene-plugins; these exist so the
/// core schemas can be exercised without any plugin.
module graphene.tests.testkit

import "../../core/provider.pkl"
import "../../core/action.pkl"
import "../../core/values.pkl"

class TestProvider extends provider.Provider {
  kind = "test"
  modes { "create" }
}

class TestConnectProvider extends provider.Provider {
  kind = "test-ssh"
  modes { "connect" }
}

open class TestAction extends action.Action {
  cmd: String = "true"
  env: Mapping<String, values.Value>
}

/// Published contract — pure schema, nothing instantiated: the class
/// describes the outputs, the base builds `startCluster.outputs.endpoint`
/// from it by reflection. The class is also the codegen target the
/// executor fills at runtime.
class ClusterStartOutputs extends action.Outputs {
  endpoint: values.RuntimeRef
}

class ClusterStart extends TestAction {
  outputsSchema = ClusterStartOutputs
}

/// Artifacts contract, same convention.
class SuiteRunArtifacts extends action.Artifacts {
  report: values.ArtifactRef
}

class SuiteRun extends TestAction {
  artifactsSchema = SuiteRunArtifacts
}

/// Artifact-publishing cleanup helper, same convention.
class LogCollectArtifacts extends action.Artifacts {
  logs: values.ArtifactRef
}

class LogCollect extends TestAction {
  artifactsSchema = LogCollectArtifacts
}
