/// The dogfood shape: N uniform cluster hosts by eval-time iteration,
/// a persistent claim, edge conditions (always-cleanup), grants
/// accumulating across jobs on the same host, inputs, outputs,
/// artifacts, secrets.
module tests.valid.cluster

extends "../../core/template.pkl"

import "../../core/resource.pkl"
import "../../core/host.pkl"
import "../../core/job.pkl"
import "../../core/values.pkl"
import "../support/testkit.pkl"

nodeCount = 3

nodeResources: Listing<resource.EphemeralResource> = new {
  for (i in List(0, 1, 2)) {
    new {
      name = "node-res-\(i)"
      provider = new testkit.TestProvider { provides { "bash" } }
      hardware { cpu = 4; ram = 8.gib; disk = 50.gib }
    }
  }
}

nodeHosts: Listing<host.Host> = new {
  for (i in List(0, 1, 2)) {
    new {
      name = "node-\(i)"
      backedBy = nodeResources[i]
    }
  }
}

appRes: resource.PersistentClaim = new {
  name = "app-res"
  registryRef = "app-staging"
  providerKind = "test-ssh"
  provides { "bash"; "systemd" }
}

app: host.Host = new {
  name = "app"
  backedBy = appRes
}

prepare: job.Job = new {
  name = "prepare"
  runsOn = nodeHosts[0]
  actions {
    new testkit.TestAction {
      name = "install-tools"
      cmd = "apt-get install -y docker.io"
      requires { "bash" }
      grants { "docker" }
    }
  }
}

// Actions with published contracts live as named top-level values:
// consumers reference typed fields directly (startCluster.endpoint) —
// IDE-navigable, a typo is an eval error.
startCluster: testkit.ClusterStart = new {
  name = "start-cluster"
  cmd = "docker compose up -d"
  requires { "docker" }  // granted by prepare on the same host
  env {
    ["TOKEN"] = values.secretKey("vault/cluster", "token")
    ["VERSION"] = module.input("version")
  }
}

runSuite: testkit.SuiteRun = new {
  name = "run-suite"
  cmd = "pytest"
  requires { "bash" }
  env {
    ["ENDPOINT"] = startCluster.endpoint
  }
}

deploy: job.Job = new {
  name = "deploy"
  runsOn = nodeHosts[0]
  needs { prepare }
  actions { startCluster }
}

test: job.Job = new {
  name = "test"
  runsOn = app
  needs { deploy }
  actions { runSuite }
}

collectLogs: testkit.LogCollect = new {
  name = "collect-logs"
  cmd = "tar czf logs.tgz /var/log"
  requires { "bash" }
}

cleanup: job.Job = new {
  name = "cleanup"
  runsOn = nodeHosts[0]
  needs {
    new job.Dependency { job = test; on = "always" }
  }
  actions { collectLogs }
}

wf {
  name = "cluster-test"
  inputs {
    ["version"] { description = "version under test"; default = "0.0.0-dev" }
  }
  resources { ...nodeResources; appRes }
  hosts { ...nodeHosts; app }
  jobs { prepare; deploy; test; cleanup }
}
